# =============================================================================
# AWS Bedrock Configuration
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# =============================================================================
# Qdrant Vector Store
# =============================================================================
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=austenancy_tenancy_acts

# =============================================================================
# LLM Fallback Providers
# =============================================================================
OPENAI_API_KEY=
GOOGLE_API_KEY=

# =============================================================================
# LangSmith Tracing (Optional) — see docs/LANGSMITH_SETUP.md
# =============================================================================
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aus-tenancy-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=true

# =============================================================================
# Application Configuration
# =============================================================================
LOG_LEVEL=INFO
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5

# =============================================================================
# Mem0 Cross-Session Memory (Optional) — see docs/AGENT_WORKFLOW.md §5
# =============================================================================
MEM0_API_KEY=
MEM0_ORG_ID=
